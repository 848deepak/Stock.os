# AWS frontend API URL configuration (no custom domain required)
#
# Recommended (no domain, single EC2 host with Nginx reverse proxy):
# Serve frontend and backend from same origin, and proxy /api -> backend.
# Then keep API as relative path:
VITE_API_URL=/api
#
# Option 2 (direct backend by EC2 public IP):
# VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:8080/api
#
# Option 3 (if you later use a custom API endpoint or domain):
# VITE_API_URL=https://YOUR_API_HOST
